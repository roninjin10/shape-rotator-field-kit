#!/usr/bin/env bash
# kit — unified entry point for the shape rotator field kit
#
# After `./kit install-global`, this same file is reachable as `rotate`
# (and `shape-rotator-kit`) from anywhere on PATH.
#
# Subcommands:
#   rotate setup               run the full installer (same as `bash setup.sh`)
#   rotate doctor              check every tool is installed and reachable
#   rotate update              bump every submodule to its upstream main
#   rotate research "..."      invoke the research-swarm agent
#   rotate vox                 launch voxterm
#   rotate help                this help

set -euo pipefail

# Resolve the real path of this script even when invoked through a
# symlink (e.g. ~/.local/bin/rotate → /path/to/kit). Without this,
# $KIT_ROOT ends up being the symlink's directory and all the
# repo-relative checks break.
_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  case "$_src" in /*) ;; *) _src="$_dir/$_src" ;; esac
done
KIT_ROOT="$(cd -P "$(dirname "$_src")" && pwd)"
unset _src _dir
cd "$KIT_ROOT"

if [ -t 1 ]; then
  BOLD='\033[1m'; DIM='\033[2m'; CYAN='\033[36m'; GREEN='\033[32m'
  YELLOW='\033[33m'; RED='\033[31m'; RESET='\033[0m'
else
  BOLD=''; DIM=''; CYAN=''; GREEN=''; YELLOW=''; RED=''; RESET=''
fi

ok()   { printf "${GREEN}✓${RESET} %s\n" "$*"; }
miss() { printf "${RED}✗${RESET} %s\n" "$*"; }
warn() { printf "${YELLOW}!${RESET} %s\n" "$*"; }

cmd="${1:-help}"
shift || true

case "$cmd" in
  setup)
    exec bash "$KIT_ROOT/setup.sh" "$@"
    ;;

  doctor)
    printf "${BOLD}shape-rotator-field-kit · doctor${RESET}\n\n"
    # voxterm
    if command -v voxterm >/dev/null 2>&1; then
      ok "voxterm         $(command -v voxterm)"
    else
      miss "voxterm         not on PATH — run 'kit setup'"
    fi
    # research-swarm
    if [ -x "$KIT_ROOT/research-swarm/.venv/bin/research-agent" ]; then
      ok "research-swarm  $KIT_ROOT/research-swarm/.venv/bin/research-agent"
    else
      miss "research-swarm  venv missing — run 'kit setup'"
    fi
    # .env sanity
    if [ -f "$KIT_ROOT/research-swarm/.env" ]; then
      if grep -qE '^(LM_MODEL|ANTHROPIC_API_KEY)=' "$KIT_ROOT/research-swarm/.env"; then
        ok "research-swarm/.env  LM configured"
      else
        warn "research-swarm/.env  exists but no LM_MODEL / ANTHROPIC_API_KEY set"
      fi
    else
      warn "research-swarm/.env  missing — copy .env.example and set an LM"
    fi
    # submodules pinned
    echo
    printf "${BOLD}pinned commits:${RESET}\n"
    git submodule status | sed 's/^/  /'
    ;;

  update)
    printf "${BOLD}bumping every submodule to upstream main${RESET}\n\n"
    git submodule update --remote --recursive
    git submodule status | sed 's/^/  /'
    echo
    warn "pins are updated in the working tree but NOT committed."
    echo "  review changes, then:  git add . && git commit -m 'bump submodules'"
    ;;

  research)
    if [ ! -x "$KIT_ROOT/bin/research-agent" ]; then
      miss "research-agent wrapper missing. Run: kit setup"
      exit 1
    fi
    exec "$KIT_ROOT/bin/research-agent" "$@"
    ;;

  vox)
    if ! command -v voxterm >/dev/null 2>&1; then
      miss "voxterm not on PATH. Run: kit setup"
      exit 1
    fi
    exec voxterm "$@"
    ;;

  install-global)
    # Put `srk` and `shape-rotator-kit` on PATH, export SHAPE_ROTATOR_KIT_PATH
    # in the shell rc, and (if ~/.claude/CLAUDE.md exists) point Claude at
    # this kit's AGENTS.md. Idempotent via marker blocks. Reversible via
    # `kit uninstall-global`.

    BEGIN_MARK="# >>> shape-rotator-field-kit >>>"
    END_MARK="# <<< shape-rotator-field-kit <<<"
    LOCAL_BIN="$HOME/.local/bin"

    printf "${BOLD}installing shape-rotator-field-kit globally${RESET}\n\n"

    # 1) Symlinks
    mkdir -p "$LOCAL_BIN"

    # Warn if `rotate` already points somewhere else on PATH (not our own
    # prior symlink). Shadowing an existing binary is the user's call.
    existing="$(command -v rotate 2>/dev/null || true)"
    if [ -n "$existing" ] && [ "$existing" != "$LOCAL_BIN/rotate" ]; then
      warn "'rotate' already on PATH at $existing — this install will shadow it"
    fi

    ln -sfn "$KIT_ROOT/kit" "$LOCAL_BIN/rotate"
    ln -sfn "$KIT_ROOT/kit" "$LOCAL_BIN/shape-rotator-kit"
    ok "symlinked $LOCAL_BIN/rotate              → $KIT_ROOT/kit"
    ok "symlinked $LOCAL_BIN/shape-rotator-kit   → $KIT_ROOT/kit"

    # If a prior install left an `srk` symlink (the old short name), remove
    # it so uninstalls stay consistent.
    if [ -L "$LOCAL_BIN/srk" ]; then
      rm -f "$LOCAL_BIN/srk"
      ok "removed legacy symlink $LOCAL_BIN/srk"
    fi

    if ! printf '%s' ":$PATH:" | grep -q ":$LOCAL_BIN:"; then
      warn "$LOCAL_BIN is not on your PATH in this shell."
      echo "   Add this line to your shell rc, then 'exec zsh' (or restart):"
      echo "     export PATH=\"\$HOME/.local/bin:\$PATH\""
    fi

    # 2) Shell rc: export env vars
    case "$SHELL" in
      */zsh)  RC="$HOME/.zshrc"  ;;
      */bash) RC="$HOME/.bashrc" ;;
      *)      RC="" ;;
    esac

    if [ -n "$RC" ]; then
      BLOCK="
$BEGIN_MARK
export SHAPE_ROTATOR_KIT_PATH=\"$KIT_ROOT\"
export SHAPE_ROTATOR_KIT_AGENTS_MD=\"\$SHAPE_ROTATOR_KIT_PATH/AGENTS.md\"
$END_MARK
"
      # Ensure the rc file exists
      touch "$RC"
      # Remove any prior block, then append the fresh one
      python3 - "$RC" "$BEGIN_MARK" "$END_MARK" <<'PY' 2>/dev/null || warn "python3 not available; appending without dedup"
import re, sys
path, begin, end = sys.argv[1:4]
txt = open(path).read()
pattern = re.compile(r'\n?' + re.escape(begin) + r'.*?' + re.escape(end) + r'\n?', re.DOTALL)
open(path, 'w').write(pattern.sub('\n', txt))
PY
      printf '%s' "$BLOCK" >> "$RC"
      ok "wrote env-var block to $RC"
    else
      warn "could not detect shell (\$SHELL='$SHELL'). Skipping rc edit."
      echo "   Add this to your shell config manually:"
      echo "     export SHAPE_ROTATOR_KIT_PATH=\"$KIT_ROOT\""
    fi

    # 3) Claude Code pointer (only if ~/.claude/ exists)
    if [ -d "$HOME/.claude" ]; then
      CC_MD="$HOME/.claude/CLAUDE.md"
      CC_BLOCK="
$BEGIN_MARK
## shape-rotator-field-kit

A bundle of local-first tools (research agent, voice transcription, more).
Lives at: $KIT_ROOT

For tool usage, commands, and conventions, read:
  $KIT_ROOT/AGENTS.md

Quick commands from anywhere on this machine:
  rotate research \"question\"  DSPy ReAct research agent
  rotate vox                   voxterm voice transcription TUI
  rotate doctor                health check
  rotate help                  full command list

\`shape-rotator-kit\` is the same binary if you prefer the explicit name.
$END_MARK
"
      touch "$CC_MD"
      python3 - "$CC_MD" "$BEGIN_MARK" "$END_MARK" <<'PY' 2>/dev/null || true
import re, sys
path, begin, end = sys.argv[1:4]
txt = open(path).read()
pattern = re.compile(r'\n?' + re.escape(begin) + r'.*?' + re.escape(end) + r'\n?', re.DOTALL)
open(path, 'w').write(pattern.sub('\n', txt))
PY
      printf '%s' "$CC_BLOCK" >> "$CC_MD"
      ok "appended field-kit pointer to $CC_MD"
    else
      printf "${DIM}(~/.claude/ not present; skipped Claude-specific pointer)${RESET}\n"
    fi

    echo
    printf "${BOLD}done${RESET}\n"
    echo "  · open a new shell (or 'exec \$SHELL') and try:  rotate help"
    echo "  · to undo this:                                 rotate uninstall-global"
    ;;

  uninstall-global)
    BEGIN_MARK="# >>> shape-rotator-field-kit >>>"
    END_MARK="# <<< shape-rotator-field-kit <<<"
    LOCAL_BIN="$HOME/.local/bin"

    printf "${BOLD}removing global install${RESET}\n\n"

    # Remove all known symlinks, including the legacy 'srk' name so users
    # who installed under the old name also get a clean uninstall.
    for link in "$LOCAL_BIN/rotate" "$LOCAL_BIN/shape-rotator-kit" "$LOCAL_BIN/srk"; do
      if [ -L "$link" ]; then
        rm -f "$link"
        ok "removed symlink $link"
      fi
    done

    for RC in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.claude/CLAUDE.md"; do
      [ -f "$RC" ] || continue
      if grep -qF "$BEGIN_MARK" "$RC"; then
        python3 - "$RC" "$BEGIN_MARK" "$END_MARK" <<'PY' 2>/dev/null || continue
import re, sys
path, begin, end = sys.argv[1:4]
txt = open(path).read()
pattern = re.compile(r'\n?' + re.escape(begin) + r'.*?' + re.escape(end) + r'\n?', re.DOTALL)
open(path, 'w').write(pattern.sub('\n', txt))
PY
        ok "removed field-kit block from $RC"
      fi
    done

    echo
    printf "${BOLD}done${RESET}  · open a new shell to pick up the change.\n"
    ;;

  help|-h|--help|"")
    cat <<EOF
${BOLD}kit${RESET} — shape-rotator-field-kit dispatcher

Also invokable as: ${BOLD}rotate${RESET} or ${BOLD}shape-rotator-kit${RESET} after \`kit install-global\`.

${BOLD}install & maintain${RESET}
  kit setup                 bootstrap every tool (idempotent)
  kit install-global        add \`rotate\` / \`shape-rotator-kit\` to PATH,
                            export SHAPE_ROTATOR_KIT_PATH in your shell rc,
                            point ~/.claude/CLAUDE.md at AGENTS.md (if present)
  kit uninstall-global      reverse install-global cleanly
  kit update                bump every submodule to upstream main
  kit doctor                check each tool is installed + configured

${BOLD}invoke tools${RESET}
  kit research "question"   run the research-swarm agent
  kit vox                   launch voxterm

${DIM}All subcommands pass extra args through.
Example:  rotate research --parallel "survey modern mixnets"${RESET}
EOF
    ;;

  *)
    miss "unknown subcommand: $cmd"
    echo
    exec "$0" help
    ;;
esac
